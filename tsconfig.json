{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./",
    "lib": ["DOM", "ES2020"],
    "noEmitOnError": false
  },
  "include": ["firsttype.ts"],
  "exclude": ["dist", "node_modules"]
}
